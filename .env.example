# Agent Pulsar Configuration
# Copy this file to .env and fill in required values.
#
# Only AP_ANTHROPIC_API_KEY is required. Everything else has sensible defaults
# for local development.

# ============================================================================
# REQUIRED
# ============================================================================

# Your Anthropic API key (get one at https://console.anthropic.com)
AP_ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# INFRASTRUCTURE (defaults work for local Docker Compose)
# ============================================================================

# Redis — event bus + cache
AP_REDIS_URL=redis://localhost:6379/0

# PostgreSQL — task state persistence
AP_DATABASE_URL=postgresql+asyncpg://agent_pulsar:agent_pulsar@localhost:5432/agent_pulsar

# ============================================================================
# SUPERVISOR (control plane)
# ============================================================================

AP_SUPERVISOR_HOST=0.0.0.0
AP_SUPERVISOR_PORT=8100

# LLM models — which Claude models to use for decomposition and classification
AP_DECOMPOSITION_MODEL=claude-opus-4-0-20250514
AP_CLASSIFICATION_MODEL=claude-haiku-4-5-20250414

# Event bus settings
AP_CONSUMER_GROUP=agent-pulsar-supervisor
AP_EVENT_BUS_POLL_MS=1000
AP_MAX_RETRIES=3

# ============================================================================
# OPENCLAW INTEGRATION
# ============================================================================

# Webhook URL where OpenClaw receives task completion results
AP_OPENCLAW_WEBHOOK_URL=http://localhost:18789/hooks/agent

# ============================================================================
# VAULT — credential storage (optional for dev, recommended for production)
# ============================================================================

# Leave unset to use in-memory storage (dev mode). Set both for real Vault.
# AP_VAULT_URL=http://localhost:8200
# AP_VAULT_TOKEN=
# AP_VAULT_MOUNT_POINT=secret

# ============================================================================
# TOKEN BROKER — JWT credential issuance (Phase 2)
# ============================================================================

# IMPORTANT: Change the secret in production!
AP_TOKEN_BROKER_SECRET=dev-secret-change-me
AP_TOKEN_BROKER_HOST=0.0.0.0
AP_TOKEN_BROKER_PORT=8101
AP_TOKEN_BROKER_URL=http://localhost:8101
AP_DEFAULT_TOKEN_TTL_SECONDS=300

# ============================================================================
# CONFIG PORTAL — credential onboarding UI (Phase 2)
# ============================================================================

AP_CONFIG_PORTAL_HOST=0.0.0.0
AP_CONFIG_PORTAL_PORT=8102
AP_CONFIG_PORTAL_BASE_URL=http://localhost:8102
AP_ONBOARDING_LINK_TTL_SECONDS=600

# ============================================================================
# COLD TIER — Docker execution for sensitive tasks (Phase 2)
# ============================================================================

AP_DOCKER_NETWORK=agent-pulsar-net
AP_COLD_TIER_MEM_LIMIT=512m
AP_COLD_TIER_CPU_QUOTA=50000

# ============================================================================
# SETUP WIZARD
# ============================================================================

AP_SETUP_WIZARD_HOST=0.0.0.0
AP_SETUP_WIZARD_PORT=8103
